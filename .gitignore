# ╔══════════════════════════════════════════════════════════════╗
# ║              🛡️ Universal .gitignore                       ║
# ║     Covers: Security, DevOps, Web, Mobile & More           ║
# ╚══════════════════════════════════════════════════════════════╝

# ============================================================
# 🔐 SECURITY — Secrets, Keys, Credentials (CRITICAL)
# ============================================================

# SSH & GPG Keys
*.pem
*.key
*.pub
*.ppk
*.p12
*.pfx
*.keystore
*.jks
id_rsa
id_ed25519
id_ecdsa
*.gpg
*.asc

# Certificates & SSL
*.crt
*.csr
*.cer
*.der

# Passwords & Secrets
*.secret
*.secrets
*.password
*.passwords
consul-key.txt
vault-token.txt
*-token.txt
*-key.txt

# Environment Files
.env
.env.*
!.env.example
!.env.sample
!.env.template

# Ansible Vault
*.vault
*vault*.yml
!*vault*.yml.example
ansible-vault-password
vault-password.txt

# Terraform
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform/
crash.log

# Docker secrets
docker-compose.override.yml
docker-compose.*.yml
!docker-compose.yml
!docker-compose.example.yml

# Cloud Provider Credentials
.aws/
.azure/
.gcp/
credentials
credentials.json
service-account*.json
gcloud-key*.json

# API Keys & Tokens
*_token
*_apikey
*.token
api_key*
apikey*

